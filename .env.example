# LONGCAT_API_KEY: Required for server-side LongCat AI calls (OpenAI-compatible API).
# Keep this server-only. Do not expose it with VITE_ or inject it into frontend bundles.
LONGCAT_API_KEY="MY_LONGCAT_API_KEY"

# Optional overrides — leave unset to use defaults.
# LONGCAT_API_URL="https://api.longcat.chat/openai/v1/chat/completions"
# LONGCAT_MODEL="LongCat-Flash-Chat"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
